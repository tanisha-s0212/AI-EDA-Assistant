COMPOSE_PROJECT_NAME=ai-eda-assistant
POSTGRES_PORT=5432
NGINX_PORT=8888
PGADMIN_PORT=5050
ACTIVITY_DB_CONNECT_TIMEOUT=1
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=ai_eda_assistant
ACTIVITY_DATABASE_URL=postgresql://agent:agent@host.docker.internal:5432/ai_eda_assistant
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123
